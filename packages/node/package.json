{
  "name": "@churnkey/node",
  "version": "0.1.0",
  "description": "Server-side SDK for Churnkey. Generate session tokens for use with @churnkey/react.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/churnkey/sdk.git",
    "directory": "packages/node"
  },
  "keywords": ["churnkey", "node", "server", "subscription", "retention", "cancel-flow"],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
